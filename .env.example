# ──────────────────────────────────────────────────────────────────────────────
# CodeMaarg — Environment Variables
# Copy this file to .env and fill in the values.
# ──────────────────────────────────────────────────────────────────────────────

# ── PostgreSQL (Prisma) ──────────────────────────────────────────────────────
# For local dev:  postgresql://USER:PASSWORD@localhost:5432/codemaarg
# For Accelerate: prisma://accelerate.prisma-data.net/?api_key=YOUR_KEY
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/codemaarg"

# ── MongoDB Atlas (Vector Search) ────────────────────────────────────────────
MONGODB_URI="mongodb+srv://user:password@cluster.mongodb.net/?retryWrites=true&w=majority"
MONGODB_DB_NAME="codemaarg"

# ── OpenAI / LLM Provider ───────────────────────────────────────────────────
OPENAI_API_KEY="sk-..."
# OPENAI_BASE_URL=              # Uncomment to use Groq, Together, etc.
# OPENAI_MODEL="gpt-4o"        # Override the default model
